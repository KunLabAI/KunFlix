# =============================================================================
# KunFlix Backend - 环境变量样例
# 复制为 .env 后按需覆盖；保持默认值即可在本地 SQLite + 内存缓存运行。
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# 默认使用 backend/kunflix.db SQLite 文件，生产建议切 PostgreSQL：
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/kunflix
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/kunflix_db

# 连接池（PostgreSQL 生产建议值：POOL_SIZE=20, MAX_OVERFLOW=30）
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# -----------------------------------------------------------------------------
# Cache backend —— 开发零依赖、生产显式启用
#   - 开发环境：留空 REDIS_URL，全部走本地内存降级（Cache/PubSub/SSE Stream/限流/
#     JWT 黑名单 全部 no-op 或进程内实现，单实例完全可用）
#   - 生产环境：取消注释并填写 redis://host:6379/0，自动激活跨实例一致性能力
# -----------------------------------------------------------------------------
CACHE_BACKEND=memory
# REDIS_URL=redis://localhost:6379/0

# Agent 实例缓存（user_config 粒度）
AGENT_CACHE_MAX_SIZE=256
AGENT_CACHE_TTL_SECONDS=600

# LLM model 实例缓存（provider.id 粒度）
MODEL_CACHE_MAX_SIZE=64
MODEL_CACHE_TTL_SECONDS=1800

# -----------------------------------------------------------------------------
# Storage backend：local | s3（同时兼容 MinIO/R2/OSS）
# -----------------------------------------------------------------------------
STORAGE_BACKEND=local
# 留空使用默认的 backend/media 目录
STORAGE_LOCAL_BASE_DIR=

# S3 / MinIO / Cloudflare R2 / 阿里 OSS（STORAGE_BACKEND=s3 时生效）
# MinIO 本地示例：STORAGE_S3_ENDPOINT=http://localhost:9000
STORAGE_S3_ENDPOINT=
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
# CDN/公网访问前缀，例：https://cdn.example.com；留空则返回预签名 GET URL
STORAGE_S3_PUBLIC_BASE_URL=
# MinIO 需 true；AWS S3 可设 false
STORAGE_S3_USE_PATH_STYLE=true
STORAGE_PRESIGN_EXPIRES=3600

# -----------------------------------------------------------------------------
# Security —— API Key 字段级加密（Fernet）
# 生成方式：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 留空则透传明文（向后兼容存量数据）
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# AI Models
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
STORY_GENERATION_MODEL=gpt-4-turbo

# -----------------------------------------------------------------------------
# JWT Auth
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# CORS（逗号分隔，写入 settings.CORS_ALLOW_ORIGINS）
# -----------------------------------------------------------------------------
CORS_ALLOW_ORIGINS=http://localhost:3666,http://127.0.0.1:3666,http://localhost:3888,http://127.0.0.1:3888

# -----------------------------------------------------------------------------
# Task queue (arq)
# -----------------------------------------------------------------------------
QUEUE_BACKEND=memory
# 留空则复用 REDIS_URL
QUEUE_REDIS_URL=

# -----------------------------------------------------------------------------
# Rate limit & circuit breaker
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=false
RATE_LIMIT_DEFAULT=100/minute
# 高频端点细粒度限流（默认值已内置，特殊场景再调低）
RATE_LIMIT_CHAT_SEND=60/minute
RATE_LIMIT_VIDEO_CREATE=20/minute
RATE_LIMIT_IMAGE_GENERATE=20/minute
RATE_LIMIT_MUSIC_CREATE=20/minute
RATE_LIMIT_ORCHESTRATE=30/minute
CIRCUIT_BREAKER_ENABLED=false
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TTL=30

# -----------------------------------------------------------------------------
# Audit log
# -----------------------------------------------------------------------------
AUDIT_ENABLED=true

# -----------------------------------------------------------------------------
# SSE resumable stream (Redis Stream)
# 未配置 REDIS_URL 时自动降级为 no-op；配置后客户端可通过
# `GET /api/sse/resume/{scope}/{ref_id}` + `Last-Event-ID` 续传
# -----------------------------------------------------------------------------
SSE_STREAM_MAXLEN=1000
SSE_STREAM_TTL_SEC=600
SSE_RESUME_MAX_COUNT=500

# -----------------------------------------------------------------------------
# System
# -----------------------------------------------------------------------------
# 启动时是否自动运行 Alembic 升级（生产建议外部 pipeline 单独触发）
RUN_MIGRATIONS=false
